# TrajectoryRL Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# =============================================================================
# LLM API Configuration (OpenAI-compatible)
# =============================================================================

# API key for the LLM provider (required for ClawBench evaluation)
CLAWBENCH_LLM_API_KEY=

# Base URL for the OpenAI-compatible API (required)
# Examples:
#   https://open.bigmodel.cn/api/paas/v4   (Zhipu GLM, default)
#   https://api.openai.com/v1              (OpenAI)
#   https://api.deepseek.com               (DeepSeek)
#   http://localhost:11434/v1              (Ollama)
#   http://localhost:8000/v1               (vLLM)
CLAWBENCH_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# =============================================================================
# Model Selection
# =============================================================================
# LLM model for evaluation (provider/model format)
# The prefix must match a provider defined in clawbench/config/openclaw.json.template.
# Examples:
#   zhipu/glm-5                            (Zhipu GLM, default)
#   openai/gpt-4o                          (OpenAI)
#   deepseek/deepseek-chat                 (DeepSeek)
CLAWBENCH_DEFAULT_MODEL=zhipu/glm-5

# =============================================================================
# Bittensor
# =============================================================================
WALLET_NAME=validator
WALLET_HOTKEY=default
NETUID=11
NETWORK=finney          # finney, test, or local

# =============================================================================
# Optional
# =============================================================================
# EVAL_INTERVAL_BLOCKS=1200  # Blocks between evaluation rounds (default: 1200 ≈ 4h)
# WEIGHT_INTERVAL_BLOCKS=360 # Blocks between weight updates (default: 360 ≈ 72min)
# LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
