# TrajectoryRL Miner — Environment Configuration
#
# Copy to .env.miner and fill in your values:
#   cp .env.miner.example .env.miner
#
# The daemon reads these when running:
#   python neurons/miner.py

# --- Bittensor ---
WALLET_NAME=miner
WALLET_HOTKEY=default
NETUID=11
NETWORK=finney

# --- Pack source (set ONE of these) ---
# Path to an existing pack.json:
PACK_PATH=/app/packs/pack.json
# OR path to AGENTS.md (daemon builds pack on the fly):
# AGENTS_MD_PATH=/app/packs/AGENTS.md

# --- HTTP URL for pack hosting ---
# Public URL where the validator can fetch your pack.json.
# Examples:
#   PACK_URL=https://my-bucket.s3.amazonaws.com/pack.json
#   PACK_URL=https://storage.googleapis.com/my-bucket/pack.json
#   PACK_URL=https://myserver.com/packs/pack.json
# PACK_URL=

# --- LLM config (default mode) ---
# Required for: python neurons/miner.py run --mode default
#
# API key for the LLM provider:
# LLM_API_KEY=
#
# Base URL for the OpenAI-compatible API:
# Examples:
#   https://open.bigmodel.cn/api/paas/v4   (Zhipu GLM, default)
#   https://api.openai.com/v1              (OpenAI)
#   https://api.deepseek.com               (DeepSeek)
#   http://localhost:11434/v1              (Ollama)
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#
# Model name (sent as the "model" field in OpenAI-compatible requests):
# LLM_MODEL=glm-5

# --- S3-compatible upload (default mode, unless PACK_URL is set) ---
# Works with AWS S3, GCS (HMAC keys), MinIO, Cloudflare R2.
# S3_BUCKET=my-trajectoryrl-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=             # optional: e.g. https://storage.googleapis.com for GCS
# AWS_ACCESS_KEY_ID=           # or GCS HMAC access key
# AWS_SECRET_ACCESS_KEY=       # or GCS HMAC secret key

# --- Daemon settings ---
# Seconds between check/submit cycles (default: 3600 = 1 hour)
CHECK_INTERVAL=3600

# --- Logging ---
LOG_LEVEL=INFO
