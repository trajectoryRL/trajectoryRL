# TrajectoryRL Miner — Environment Configuration
#
# Copy to .env.miner and fill in your values:
#   cp .env.miner.example .env.miner

# --- Bittensor ---
WALLET_NAME=miner
WALLET_HOTKEY=default
NETUID=11
NETWORK=finney

# --- Run mode ---
# "demo" submits sample pack; "default" is production skeleton
MODE=default

# --- Daemon settings ---
# Seconds between check/submit cycles (default: 3600 = 1 hour)
CHECK_INTERVAL=3600

# --- S3-compatible storage (for pack upload) ---
# Works with AWS S3, GCS, MinIO, Cloudflare R2, or any S3-compatible service.
# S3_BUCKET=my-bucket
# S3_ENDPOINT_URL=               # leave empty for AWS S3; for GCS: https://storage.googleapis.com
# S3_REGION=auto
# AWS_ACCESS_KEY_ID=              # AWS keys or GCS HMAC keys
# AWS_SECRET_ACCESS_KEY=

# --- Logging ---
LOG_LEVEL=INFO
