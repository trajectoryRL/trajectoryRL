# TrajectoryRL Miner — Environment Configuration
#
# Copy to .env.miner and fill in your values:
#   cp .env.miner.example .env.miner
#
# The daemon reads these when PACK_REPO is set and no subcommand is given:
#   python neurons/miner.py

# --- Bittensor ---
WALLET_NAME=miner
WALLET_HOTKEY=default
NETUID=11
NETWORK=finney

# --- Pack source (set ONE of these) ---
# Path to an existing pack.json:
PACK_PATH=/app/packs/pack.json
# OR path to AGENTS.md (daemon builds pack on the fly):
# AGENTS_MD_PATH=/app/packs/AGENTS.md

# --- GitHub repo (optional — one upload method, S3/web-server coming soon) ---
# "owner/repo" format — the repo where pack.json is pushed
# PACK_REPO=
# Local git clone of PACK_REPO (daemon writes pack.json here, commits, pushes)
# REPO_PATH=/app/packs

# --- Daemon settings ---
# Seconds between check/submit cycles (default: 3600 = 1 hour)
CHECK_INTERVAL=3600

# --- Logging ---
LOG_LEVEL=INFO

# --- GitHub auth (only needed if using git push upload) ---
# GITHUB_TOKEN=ghp_...
