# TrajectoryRL Configuration
# Copy to .env.validator and fill in your values:  cp .env.validator.example .env.validator

# =============================================================================
# LLM API Configuration (OpenAI-compatible)
# =============================================================================

# API key for the LLM provider (required)
# For Zhipu AI: get your key at https://open.bigmodel.cn
# For Chutes: get your key at https://chutes.ai
# For OpenRouter: get your key at https://openrouter.ai/keys
LLM_API_KEY=

# Base URL for the OpenAI-compatible API (required)
# Examples:
#   https://open.bigmodel.cn/api/paas/v4   (Zhipu AI, default)
#   https://llm.chutes.ai/v1               (Chutes, alternative)
#   https://openrouter.ai/api/v1           (OpenRouter, multi-provider)
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# =============================================================================
# Model Selection
# =============================================================================
# LLM model for evaluation (e.g. glm-5.1)
LLM_MODEL=glm-5.1

# =============================================================================
# Bittensor
# =============================================================================
WALLET_NAME=validator
WALLET_HOTKEY=default
NETUID=11
NETWORK=finney          # finney, test, or local

# =============================================================================
# IPFS (Consensus Payload Storage)
# =============================================================================
# IPFS_API_URL: kubo HTTP API endpoint (including /api/v0 prefix).
#   Used for upload (POST /add) and primary download (POST /cat).
#
# IPFS_GATEWAYS: Comma-separated public gateways for download fallback.
#   Tried sequentially if kubo API download fails.
#
# Default: uses ipfs.metahash73.com shared node with ipfs.io + cloudflare fallback.
# Override IPFS_API_URL to use your own kubo node (e.g. http://localhost:5001/api/v0).
#
# IPFS_API_URL=http://ipfs.metahash73.com:5001/api/v0
# IPFS_GATEWAYS=https://ipfs.io,https://dweb.link

# =============================================================================
# Optional
# =============================================================================
# LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR

# =============================================================================
# Advanced (defaults are fine for most setups)
# =============================================================================
# EVAL_STATE_PATH=/var/lib/trajectoryrl/eval_state.json  # Path for persisted eval state

# Image channel for sandbox/harness images (e.g. latest, staging, v1.2.0-rc.1).
# Normally set by the compose file you launch (latest -> prod, staging -> staging).
# Override here only for special debugging.
# IMAGE_CHANNEL=latest
