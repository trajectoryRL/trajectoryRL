# TrajectoryRL Configuration
# Copy to .env.validator and fill in your values:  cp .env.validator.example .env.validator

# =============================================================================
# LLM API Configuration (OpenAI-compatible) — OpenRouter recommended
# =============================================================================
# OpenRouter is the recommended provider: one API key covers both the testee
# (Qwen3.5-35B-A3B) and the judge (GLM-5.1) without juggling vendors. Get a
# key at https://openrouter.ai/keys.

LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# Model selection — testee + independent judge
# =============================================================================
# As of v0.5.14, the recommended setup is Qwen3.5-35B-A3B as the testee
# (the agent that solves the SKILL.md task) and GLM-5.1 as the judge (the
# agent that scores the testee). The model split keeps judge bias
# uncorrelated with testee bias — the v3.4.0 codebase_fix work showed this
# pairing finally differentiates real packs from no-skill baselines.

# Testee model — what the miner's SKILL.md is being executed by.
LLM_MODEL=qwen/qwen3.5-35b-a3b

# Judge model — independent family from the testee. If JUDGE_MODEL is empty,
# judge falls back to LLM_MODEL (not recommended for production).
JUDGE_MODEL=z-ai/glm-5.1
JUDGE_API_KEY=
JUDGE_BASE_URL=https://openrouter.ai/api/v1
# Tip: leaving JUDGE_API_KEY empty re-uses LLM_API_KEY when the base URL
# matches; set it explicitly if you want a separate billing/quota lane.

# =============================================================================
# Bittensor
# =============================================================================
WALLET_NAME=validator
WALLET_HOTKEY=default
NETUID=11
NETWORK=finney          # finney, test, or local

# =============================================================================
# IPFS (Consensus Payload Storage)
# =============================================================================
# IPFS_API_URL: kubo HTTP API endpoint (including /api/v0 prefix).
#   Used for upload (POST /add) and primary download (POST /cat).
#
# IPFS_GATEWAYS: Comma-separated public gateways for download fallback.
#   Tried sequentially if kubo API download fails.
#
# Default: uses ipfs.metahash73.com shared node with ipfs.io + cloudflare fallback.
# Override IPFS_API_URL to use your own kubo node (e.g. http://localhost:5001/api/v0).
#
# IPFS_API_URL=http://ipfs.metahash73.com:5001/api/v0
# IPFS_GATEWAYS=https://ipfs.io,https://dweb.link

# =============================================================================
# Optional
# =============================================================================
# LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR

# =============================================================================
# Advanced (defaults are fine for most setups)
# =============================================================================
# EVAL_STATE_PATH=/var/lib/trajectoryrl/eval_state.json  # Path for persisted eval state

# Image channel for sandbox/harness images (e.g. latest, staging, v1.2.0-rc.1).
# Normally set by the compose file you launch (latest -> prod, staging -> staging).
# Override here only for special debugging.
# IMAGE_CHANNEL=latest

# Per-episode sandbox timeout (seconds). Default 600s — Qwen3.5 testees occasionally
# need 4-5 min on hard codebase_fix episodes; 180s (the previous default) caused
# preventable timeouts. Lower only if you're using a faster testee.
# SANDBOX_TIMEOUT_PER_EPISODE=600
